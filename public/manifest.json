{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "LaneUp2",
    "version": "0.2.0",
    "minimum-overwolf-version": "0.220.0",
    "author": "YEBal",
    "icon": "icons/icon.png",
    "icon_gray": "icons/icon_gray.png",
    "window_icon": "icons/icon.png",
    "description": "Beginner-focused League of Legends companion app with role guidance, champion select coaching, and live overlays."
  },
  "permissions": ["GameEvents", "Hotkeys", "GameInfo", "FileSystem"],
  "game_events": [5426],
  "hotkeys": {
    "toggle_app": {
      "title": "Toggle LaneUp2 desktop app",
      "action-type": "custom",
      "default": "Ctrl+Shift+L"
    },
    "toggle_overlay": {
      "title": "Toggle LaneUp2 in-game overlay",
      "action-type": "custom",
      "default": "Ctrl+Shift+Space"
    }
  },
  "launch_events": [
    {
      "event": "GameLaunch",
      "event_data": {
        "game_ids": [5426]
      },
      "start_minimized": true
    }
  ],
  "windows": {
    "background": {
      "file": "background.html",
      "is_background_page": true,
      "is_startup_window": true,
      "transparent": true,
      "show_in_taskbar": false,
      "size": { "width": 0, "height": 0 }
    },
    "desktop": {
      "file": "windows/desktop.html",
      "is_main_window": true,
      "transparent": false,
      "resizable": true,
      "show_minimize": true,
      "show_maximize": true,
      "show_in_taskbar": true,
      "use_os_windowing": true,
      "size": { "width": 1480, "height": 920 },
      "min_size": { "width": 1200, "height": 760 },
      "max_size": { "width": 2560, "height": 1440 },
      "keep_window_location": true
    },
    "in_game": {
      "file": "windows/in-game.html",
      "transparent": true,
      "resizable": false,
      "show_in_taskbar": false,
      "size": { "width": 360, "height": 720 },
      "clickthrough": false,
      "keep_window_location": true
    }
  },
  "data": {
    "start_window": "background",
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [5426]
    }
  }
}
